{
  "name": "remote-desktop",
  "version": "1.0.0",
  "description": "Electron remote desktop app with WebRTC, Socket.io and robotjs",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "start:host": "electron . --mode=host",
    "start:viewer": "electron . --mode=viewer",
    "server": "node server.js",
    "build": "electron-builder --win nsis"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "robotjs": "^0.6.0",
    "socket.io-client": "^4.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "electron": "^34.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.example.remotedesktop",
    "productName": "RemoteDesktop",
    "npmRebuild": false,
    "asar": true,
    "files": [
      "main.js",
      "server.js",
      "app-config.json",
      "renderer/**/*",
      "preload.js",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}